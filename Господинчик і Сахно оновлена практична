      "source": [
        "from transformers import pipeline\n",
        "\n",
        "\n",
        "# Завантажуємо легкі моделі (працюють швидко навіть на слабких ПК)\n",
        "classifier = pipeline(\"sentiment-analysis\", model=\"distilbert-base-uncased-finetuned-sst-2-english\")\n",
        "generator = pipeline(\"text-generation\", model=\"distilgpt2\")\n",
        "\n",
        "\n",
        "def ai_support_bot(user_review):\n",
        "    # 1. Аналіз тональності\n",
        "    analysis = classifier(user_review)[0]\n",
        "    sentiment = analysis['label']\n",
        "\n",
        "    start_phrase = \"\"\n",
        "\n",
        "    # Додаємо \"Тригер на ціну\":\n",
        "    if \"price\" in user_review.lower() or \"expensive\" in user_review.lower():\n",
        "        start_phrase = \"We always try to keep our prices fair. Let us explain...\"\n",
        "    # Новий простий тригер для проблем з доставкою\n",
        "    elif (\"delivery\" in user_review.lower() or \"shipping\" in user_review.lower()) and sentiment == \"NEGATIVE\":\n",
        "        start_phrase = \"We understand that timely delivery is crucial. Regarding the shipping issue: \"\n",
        "    # 2. Логіка вибору відповіді на основі тональності\n",
        "    elif sentiment == \"POSITIVE\":\n",
        "        start_phrase = \"It's wonderful to hear you're satisfied! We appreciate your feedback about\"\n",
        "    else: # NEGATIVE\n",
        "        start_phrase = \"We sincerely apologize for any inconvenience. Let's address your concerns about\"\n",
        "\n",
        "    # 3. Генерація персоналізованого тексту\n",
        "    # temperature=0.7 для більш передбачуваних відповідей\n",
        "    response = generator(f\"{start_phrase} {user_review[:40]}\",\n",
        "                         max_new_tokens=30,\n",
        "                         temperature=0.7,\n",
        "                         do_sample=True)\n",
        "\n",
        "    return sentiment, response[0]['generated_text']\n",
        "\n",
        "\n",
        "# Перевірка роботи з розширеним відгуком\n",
        "my_review = \"The product is great, but the delivery was late and the shipping costs were high.\"\n",
        "label, reply = ai_support_bot(my_review)\n",
        "\n",
        "\n",
        "print(f\"Аналіз: {label}\")\n",
        "print(f\"Відповідь AI: {reply}\")"
      ],
